{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "skipThirdPartyRequests": true,
    "headless": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "puppeteerExecutablePath": "",
    "inlineCss": false,
    "saveAs": "html",
    "concurrency": 2,
    "timeout": 20000,
    "include": [
      "/",
      "/tools",
      "/blog",
      "/about",
      "/contact",
      "/faq",
      "/privacy",
      "/terms",
      "/cookies",
      "/palettes",
      "/gradients",
      "/gradient-generator",
      "/tint-shade",
      "/color-blindness",
      "/color-converter",
      "/border-radius",
      "/box-shadow",
      "/glass-generator",
      "/type-scale",
      "/font-pairing",
      "/palette-url",
      "/palette-exporter",
      "/contrast-checker",
      "/text-shadow",
      "/color-harmonies",
      "/random-color",
      "/color-mixer",
      "/color-name",
      "/css-filter",
      "/spacing-scale",
      "/flexbox",
      "/grid",
      "/blog/complete-guide-color-theory-designers",
      "/blog/top-5-free-color-palette-tools-2025",
      "/blog/how-to-extract-colors-from-image",
      "/blog/wcag-color-contrast-guidelines",
      "/blog/color-psychology-customer-behavior",
      "/blog/how-to-choose-brand-color-palette",
      "/blog/color-accessibility-designing-for-color-blind-users",
      "/blog/diy-creating-color-palettes-using-color-peek",
      "/blog/cultural-significance-of-colors",
      "/blog/science-behind-color-perception",
      "/blog/what-is-color-harmony-a-beginners-guide-for-designers",
      "/blog/css-box-shadow-examples",
      "/blog/glassmorphism-ui-design-tutorial",
      "/blog/best-google-font-pairings-2025",
      "/blog/css-gradient-background-ideas",
      "/blog/tailwind-css-color-palette-guide",
      "/blog/hex-to-rgb-color-conversion-guide",
      "/blog/css-border-radius-examples",
      "/blog/web-typography-type-scale-guide",
      "/blog/dark-mode-color-palette-design",
      "/blog/color-palette-from-photo-guide",
      "/blog/ui-color-trends-2025",
      "/blog/color-contrast-accessibility-guide",
      "/blog/pastel-color-palettes-web-design",
      "/blog/design-token-color-system"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@heroicons/react": "^2.1.1",
    "@types/d3-time": "^2.1.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "framer-motion": "^10.16.4",
    "globals": "^16.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^5.0.0",
    "vite-plugin-css-injected-by-js": "4.0.1"
  },
  "dependencies": {
    "@types/react-helmet": "^6.1.11",
    "@types/react-helmet-async": "^1.0.1",
    "chart.js": "^4.4.9",
    "color-name-list": "^11.13.0",
    "colorthief": "^2.6.0",
    "culori": "^4.0.1",
    "nearest-color": "^0.4.4",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.0",
    "react-snap": "^1.23.0"
  }
}
